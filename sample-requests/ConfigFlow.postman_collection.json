{
  "info": {
    "name": "ConfigFlow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" },
    { "key": "token", "value": "" },
    { "key": "apiKey", "value": "" }
  ],
  "item": [
    {
      "name": "Admin login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/admin/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"admin@configflow.local\",\"password\":\"ChangeMe123!\"}"
        }
      }
    },
    {
      "name": "List workflows",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/admin/workflows"
      }
    },
    {
      "name": "Example 1: Verify PAN",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/verify-pan",
        "body": { "mode": "raw", "raw": "{\"pan\":\"ABCDE1234F\"}" }
      }
    },
    {
      "name": "Example 2: Validate identity",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/validate-identity",
        "body": { "mode": "raw", "raw": "{\"aadhaar\":\"123456789012\",\"gstin\":\"29ABCDE1234F1Z5\"}" }
      }
    },
    {
      "name": "Example 3: KYC onboarding",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-api-key", "value": "{{apiKey}}" }
        ],
        "url": "{{baseUrl}}/kyc-onboarding",
        "body": {
          "mode": "raw",
          "raw": "{\"documentUrl\":\"https://example.com/doc.png\",\"selfieUrl\":\"https://example.com/selfie.png\"}"
        }
      }
    },
    {
      "name": "Retry demo",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/retry-demo",
        "body": { "mode": "raw", "raw": "{\"attemptKey\":\"postman-run-1\"}" }
      }
    },
    {
      "name": "Agentic AI: generate workflow",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": "{{baseUrl}}/agent/generate-workflow",
        "body": {
          "mode": "raw",
          "raw": "{\"description\":\"Create an API that validates a PAN using Vendor A and, if successful, fetches GST details from Vendor B.\"}"
        }
      }
    },
    {
      "name": "Execution logs",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{baseUrl}}/admin/logs?limit=10"
      }
    }
  ]
}
